<?xml version="1.0" encoding="utf-8"?>
<!--
    全局设置面板 - 完全重新设计
    统一管理所有全局参数
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_medium"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="全局设置"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="@color/text_muted" />

    <!-- 渲染器选择 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="渲染器"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <RadioGroup
        android:id="@+id/group_renderer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/button_render_software"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="软件渲染 (software)"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <RadioButton
            android:id="@+id/button_render_gl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:text="硬件渲染 (gl)"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </RadioGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/bg_card" />

    <!-- 其他功能 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="其他"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <CheckBox
        android:id="@+id/button_scopedsavedir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="隔离存档目录"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <CheckBox
        android:id="@+id/button_alloweditargs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="允许编辑启动参数"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/bg_card" />

    <!-- 底部信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <Button
                android:id="@+id/button_checkupdate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/btn_primary"
                android:text="检查更新"
android:textColor="@color/white"
            android:textSize="11sp" />

            <Button
                android:id="@+id/button_about"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/btn_secondary"
                android:text="关于"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:text="@string/app_version"
            android:textColor="@color/primary"
            android:textSize="24sp" />
    </LinearLayout>

</LinearLayout>
