<?xml version="1.0" encoding="utf-8"?>
<!--
    游戏卡片 - 完全重新设计
    每个游戏以卡片形式展示，包含封面、标题和操作按钮
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_game_card"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/card_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="6dp">

    <!-- 封面图 -->
    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/cover_placeholder">

        <ImageView
            android:id="@+id/image_game_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:src="@mipmap/ic_launcher" />

        <ImageView
            android:id="@+id/image_cover_placeholder"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_cover_add"
            android:visibility="visible" />
    </FrameLayout>

    <!-- 游戏信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <!-- 游戏标题 -->
        <TextView
            android:id="@+id/text_game_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Game Title" />

        <!-- 游戏路径 -->
        <TextView
            android:id="@+id/text_game_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:maxLines="1"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            tools:text="/storage/emulated/0/games/example" />

        <!-- 有效性和类型标签 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_pathtype"
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:gravity="center"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:text="saf"
                android:textColor="@color/path_saf"
                android:textSize="10sp"
                android:background="@color/bg_card" />

            <TextView
                android:id="@+id/text_valid_badge"
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:layout_marginLeft="4dp"
                android:gravity="center"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:text="✓"
                android:textColor="@color/success"
                android:textSize="10sp"
                android:background="@color/bg_card"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 右边操作区 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- 游玩按钮 -->
        <ImageButton
            android:id="@+id/button_play_game"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/btn_primary"
            android:scaleType="center"
            android:src="@drawable/ic_play"
            android:contentDescription="启动游戏" />

        <!-- 游戏计数 -->
        <TextView
            android:id="@+id/text_game_no"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="1/1"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>