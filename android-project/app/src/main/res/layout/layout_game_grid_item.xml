<?xml version="1.0" encoding="utf-8"?>
<!--
    游戏网格项 - 用于网格视图
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg"
    android:layout_margin="4dp"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 封面图 -->
        <FrameLayout
            android:id="@+id/grid_cover_container"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/cover_placeholder">

            <ImageView
                android:id="@+id/grid_image_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                tools:src="@mipmap/ic_launcher" />

            <ImageView
                android:id="@+id/grid_cover_placeholder"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cover_add"
                android:visibility="visible" />
        </FrameLayout>

        <!-- 游戏信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/grid_game_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Game Title" />

            <TextView
                android:id="@+id/grid_game_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/primary"
                android:textSize="9sp"
                tools:text="tag1, tag2" />

            <TextView
                android:id="@+id/grid_pathtype"
                android:layout_width="wrap_content"
                android:layout_height="14dp"
                android:gravity="center"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="saf"
                android:textColor="@color/path_saf"
                android:textSize="9sp"
                android:background="@color/bg_card" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
